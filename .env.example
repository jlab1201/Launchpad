# Copy to .env.local and adjust as needed.
# Never commit .env.local — it is gitignored.

# Path to the SQLite database file (relative to project root).
DATABASE_PATH=./data/db.sqlite

# Directory where auto-captured thumbnails are stored.
THUMBNAIL_DIR=./data/thumbnails

# How long (in ms) the vault key is kept in memory without user interaction.
# Default is 30 minutes. Reduce to tighten security.
VAULT_IDLE_TIMEOUT_MS=1800000
